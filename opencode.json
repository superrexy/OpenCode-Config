{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "command": [
        "npx",
        "@playwright/mcp@latest"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "brew install *": "allow",
      "brew upgrade *": "allow",
      "bun add *": "allow",
      "chmod *": "ask",
      "chown *": "ask",
      "cp *": "allow",
      "curl *": "allow",
      "dd *": "ask",
      "docker *": "allow",
      "fdisk *": "ask",
      "format *": "ask",
      "git branch -D *": "ask",
      "git branch -d *": "allow",
      "git clean *": "ask",
      "git push": "allow",
      "git rebase *": "ask",
      "git reset --hard *": "ask",
      "kill *": "ask",
      "killall *": "ask",
      "mkdir *": "allow",
      "mkfs *": "ask",
      "mv *": "allow",
      "npm install *": "allow",
      "npm run publish": "ask",
      "parted *": "ask",
      "pip install *": "allow",
      "reboot": "ask",
      "rm *": "ask",
      "rsync *": "allow",
      "scp *": "ask",
      "shutdown": "ask",
      "ssh *": "ask",
      "sudo *": "ask",
      "touch *": "allow",
      "wget *": "allow"
    },
    "doom_loop": "ask",
    "external_directory": {
      "~/.config/opencode/get-shit-done/*": "allow"
    },
    "read": {
      "~/.config/opencode/get-shit-done/*": "allow"
    }
  },
